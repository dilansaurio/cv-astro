---

import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Generar rutas estáticas
export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((entry: CollectionEntry<'proyectos'>) => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

// 2. Obtener la entrada del proyecto
const { entry } = Astro.props as { entry: CollectionEntry<'proyectos'> };
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <article class="max-w-4xl mx-auto p-6 md:p-12">
    <header class="mb-12">
      <a href="/" class="text-orange-600 font-medium hover:underline">
        ← Volver al inicio
      </a>
      <h1 class="text-5xl font-extrabold text-gray-950 mt-6">
        {entry.data.title}
      </h1>
      <p class="text-xl text-gray-600 mt-4">
        {entry.data.description}
      </p>
      {Array.isArray(entry.data.tags) && (
        <div class="flex gap-3 mt-8">
          {entry.data.tags.map((tag: string) => (
            <span class="bg-gray-100 px-4 py-1.5 rounded-full text-sm text-gray-700 border border-gray-200">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg prose-orange max-w-none">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  @reference "../../styles/global.css";
  /* Estilos para que el contenido Markdown se vea increíble */
  .prose h2 { @apply text-3xl font-bold mt-12 mb-6 text-gray-900; }
  .prose p { @apply text-gray-700 leading-relaxed mb-6; }
  .prose code { @apply bg-gray-100 p-1 rounded text-orange-700 font-mono text-sm; }
  .prose pre { @apply bg-gray-900 p-6 rounded-2xl my-8 overflow-x-auto; }
</style>