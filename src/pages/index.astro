---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ThemeSwitcher from '../components/interactive/ThemeSwitcher';
import LanguageSwitcher from '../components/interactive/LanguageSwitcher';
import type { CollectionEntry } from 'astro:content';
import Target00 from '../content/targets/Target-00.astro';
import Target01 from '../content/targets/Target-01.astro';
import Target02 from '../content/targets/Target-02.astro';
import Target03 from '../content/targets/Target-03.astro';
import Target04 from '../content/targets/Target-04.astro';
import Target08 from '../content/targets/Target-08.astro';
import Target09 from '../content/targets/Target-09.astro';
import Target10 from '../content/targets/Target-10.astro';
// import Target06 from '../content/targets/Target-06.astro';
import Target07 from '../content/targets/Target-07.astro';

const allProyects: CollectionEntry<'proyectos'>[] = await getCollection('proyectos');
---

<Layout title=" Dilan Silva Cortes - Front-end Designer">
  <main class="main-bentogrid">
    <div class="flex justify-end gap-2 mb-3 mt-2">
      <!-- button dark mode -->
      <LanguageSwitcher client:load />
      <ThemeSwitcher client:load />
    </div>
    <!-- Bento: 1col mobile → 2col tablet → 4col desktop
         Row 1: T01 (2col)     | T02 (2col)
         Row 2: T03 (2col)     | T07 (2col)
         Row 3: T05 (2col)    | T06 (1col) | T04 (1col)  -->
    <div class="pb-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Avatar 30% + Hero 70% / row 1 -->
      <div class="col-span-1 sm:col-span-2 lg:col-span-2 grid grid-cols-[3fr_7fr] gap-4">
        <Target00 />
        <Target01 />
      </div>
      <!-- Experiencia: col 3-4 / row 1 -->
      <Target03 />
      <!-- Skills: col 1-2 / row 2 -->
      <Target02 />
      <!-- Col 3: Proyectos ocupa toda la columna -->
      <Target07 proyectos={allProyects} />
      <!-- Col 4: LinkedIn/GitHub + Trabajamos juntos + Aprendizaje -->
      <div class="flex flex-col gap-4">
        <Target08 />
        <Target09 />
        <Target04 />
      </div>
      <!-- CV comentado -->
      {/* <Target06 /> */}
    </div>
	</main>
</Layout>