<script>
  (function () {
    const svg = document.getElementById("personaje-svg") as SVGSVGElement | null;
    const ojoIzq = document.getElementById("eye-izq-wrap") as SVGGElement | null;
    const ojoDer = document.getElementById("eye-der-wrap") as SVGGElement | null;
    const narizBase   = document.getElementById("nariz-base")   as SVGRectElement | null;
    const narizShapes = document.getElementById("nariz-shapes") as SVGGElement    | null;
    const risa        = document.getElementById("risa")         as SVGPathElement | null;
    const chivo       = document.getElementById("chivo")        as SVGPathElement | null;
    const headGroup   = document.getElementById("head-group")   as SVGGElement    | null;
    if (!svg || !ojoIzq || !ojoDer || !narizBase || !narizShapes || !risa || !chivo || !headGroup) return;

    const LEFT  = { x: 123.605, y: 149.715 };
    const RIGHT = { x: 196.205, y: 149.715 };
    const MAX_EYE  = 3.5; // unidades SVG para los ojos
    const MAX_FEAT = 0.2; // unidades SVG para nariz/bigote
    const MAX_FACE = 0.5; // unidades SVG para toda la cara

    let targetEyeDX = 0, targetEyeDY = 0;
    let curEyeDX = 0, curEyeDY = 0;
    let targetFX = 0, curFX = 0;
    let targetFaceX = 0, curFaceX = 0;

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

    function animate() {
      curEyeDX = lerp(curEyeDX, targetEyeDX, 0.1);
      curEyeDY = lerp(curEyeDY, targetEyeDY, 0.1);
      curFX     = lerp(curFX,     targetFX,     0.05);
      curFaceX  = lerp(curFaceX,  targetFaceX,  0.04);

      ojoIzq.setAttribute("transform", `translate(${curEyeDX} ${curEyeDY})`);
      ojoDer.setAttribute("transform", `translate(${curEyeDX} ${curEyeDY})`);
      const ft = `translate(${curFX} 0)`;
      narizBase.setAttribute("transform",   ft);
      narizShapes.setAttribute("transform", ft);
      risa.setAttribute("transform",        ft);
      chivo.setAttribute("transform",       ft);
      headGroup.setAttribute("transform",   `translate(${curFaceX} 0)`);

      requestAnimationFrame(animate);
    }

    document.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = svg.getBoundingClientRect();
      const vb = svg.viewBox.baseVal;
      const mx = (e.clientX - rect.left) * (vb.width  / rect.width);
      const my = (e.clientY - rect.top)  * (vb.height / rect.height);

      // Ojos: dirección desde el centro de los ojos hacia el mouse
      const ecx = (LEFT.x + RIGHT.x) / 2;
      const ecy = (LEFT.y + RIGHT.y) / 2;
      const edx = mx - ecx;
      const edy = my - ecy;
      const dist = Math.sqrt(edx * edx + edy * edy) || 1;
      targetEyeDX = (edx / dist) * MAX_EYE;
      targetEyeDY = (edy / dist) * MAX_EYE;

      // Nariz/bigote: desplazamiento horizontal suave según posición X del mouse
      const normalizedX = (mx - vb.width / 2) / (vb.width / 2); // -1 a 1
      targetFX    = normalizedX * MAX_FEAT;
      targetFaceX = normalizedX * MAX_FACE;
    });

    requestAnimationFrame(animate);
  })();
</script>
