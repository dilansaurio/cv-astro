---
import type { CollectionEntry } from 'astro:content';
import ProjectsModal from '../../components/interactive/ProjectsModal';

interface Props {
  proyectos: CollectionEntry<'proyectos'>[];
}
const { proyectos } = Astro.props;

const projectsData = proyectos.map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  image: p.data.image,
  technologies: p.data.technologies,
  link: p.data.link,
  category: p.data.category,
}));
---

<div class="col-span-1 h-full bg-background-card p-5 sm:p-6 rounded-3xl border border-border flex flex-col bento-card animate-fade-up delay-4">
  <h2 class="text-lg font-semibold text-text mb-3 flex items-center justify-center gap-2">
    <iconify-icon icon="mdi:folder-multiple" class="text-primary" width="22" height="22"></iconify-icon>
    Proyectos
  </h2>
  <div class="relative flex-1 mt-4">
    <div class="grid grid-cols-2 gap-2 opacity-40 blur-[1px] pointer-events-none select-none">
      {proyectos.map((p) => (
        <div class="flex flex-col rounded-xl overflow-hidden border border-border bg-background">
          <div class="aspect-video w-full overflow-hidden">
            <img
              src={p.data.image}
              alt={p.data.title}
              width="200"
              height="113"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-2 flex flex-col gap-1.5">
            <span class="text-xs font-semibold text-text leading-tight">{p.data.title}</span>
            {p.data.technologies && p.data.technologies.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {p.data.technologies.map((tech) => (
                  <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-primary/10 text-primary font-medium leading-none">
                    {tech}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
      {proyectos.length === 0 && (
        <p class="col-span-3 text-text-muted text-xs">Próximamente...</p>
      )}
    </div>
    <div class="absolute inset-0 flex items-center justify-center">
      <ProjectsModal projects={projectsData} client:load />
    </div>
  </div>
</div>
