---
const skills = [
  {
    category: 'Desarrollo',
    items: [
      { name: 'React', icon: 'logos:react' },
      { name: 'React Native', icon: 'logos:react' },
      { name: 'Astro', icon: 'logos:astro-icon', class: 'dark:invert' },
      { name: 'TypeScript', icon: 'logos:typescript-icon' },
      { name: 'JavaScript', icon: 'logos:javascript' },
      { name: 'Tailwind CSS', icon: 'logos:tailwindcss-icon' },
    ],
  },
  {
    category: 'Diseño',
    items: [
      { name: 'Figma', icon: 'logos:figma' },
      { name: 'Photoshop', icon: 'logos:adobe-photoshop' },
      { name: 'Illustrator', icon: 'logos:adobe-illustrator' },
    ],
  },
];

---
<div class="col-span-1 sm:col-span-2 lg:col-span-2 bg-background-card p-5 sm:p-6 lg:p-6 rounded-3xl border border-border text-text flex flex-col gap-3">
  <h2 class="text-xl font-semibold text-text">Skills</h2>

  {skills.map(({ category, items }) => (
    <div class="flex items-center justify-between bg-background rounded-2xl px-5 py-4 gap-3">
      <span class="text-base font-semibold text-text whitespace-nowrap">{category}</span>
      <div class="flex items-center gap-3 flex-wrap justify-end">
        {items.map(({ name, icon, class: iconClass }) => (
          <span class="relative group/tip cursor-default">
            <iconify-icon icon={icon} width="40" height="40" class={iconClass}></iconify-icon>
            <span class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-background-card border border-border text-text text-sm font-medium rounded-lg opacity-0 group-hover/tip:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">{name}</span>
          </span>
        ))}
      </div>
    </div>
  ))}
</div>