---
const { name, role, description } = Astro.props;
---

<div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 flex flex-col mb-2">
  <h1 class="text-4xl font-bold text-gray-950">{name}</h1>
  <p class="mt-6 text-2xl font-semibold text-gray-800">{role}</p>
  <p class="mt-4 text-gray-600 text-base">{description}</p>
</div>